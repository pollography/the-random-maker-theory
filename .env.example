# Brevo Newsletter API
# Get your API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here

# Brevo List ID (find in Contacts > Lists)
BREVO_LIST_ID=2

# ─── AI Image Generation ───────────────────────────
# Together AI (DEFAULT — Flux Schnell, 3 Monate kostenlos!)
# Key holen: https://api.together.ai
TOGETHER_API_KEY=your-together-api-key-here

# Gemini API (NUR AUSSERHALB DER EU! In DE blockiert.)
