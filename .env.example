# Brevo Newsletter API
# Get your API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here

# Brevo List ID (find in Contacts > Lists)
BREVO_LIST_ID=2

# Umami Analytics
# Self-hosted: https://umami.is/docs/install
# Cloud: https://cloud.umami.is
# Die Website-ID findest du unter Settings > Websites in Umami
# Trag sie in src/app.html ein (data-website-id Attribut)
# Die Script-URL (src) anpassen an deine Umami-Instanz
