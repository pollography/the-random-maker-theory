{
	"name": "the-random-maker-theory",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"style:blocks": "python3 scripts/apply-reading-flow-blocks.py --synthesize-tldr",
		"style:blocks:drafts": "python3 scripts/apply-reading-flow-blocks.py --include-drafts --synthesize-tldr",
		"style:blocks:dry": "python3 scripts/apply-reading-flow-blocks.py --synthesize-tldr --dry-run",
		"images:regen": "node scripts/generate-blog-images.mjs",
		"images:regen:post": "node scripts/generate-blog-images.mjs --force-regen --post"
	},
	"dependencies": {
		"@google/genai": "^1.44.0",
		"feed": "^4.2.2"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-vercel": "^5.4.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.15",
		"autoprefixer": "^10.4.20",
		"mdsvex": "^0.11.1",
		"postcss": "^8.4.43",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
